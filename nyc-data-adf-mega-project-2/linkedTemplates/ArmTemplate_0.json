									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "bronze_trip_zone_lookup",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "bronze_tip_zone_lookup_csv",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-06-29T00:07:35Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/bronze_trip_type')]",
				"[concat(variables('factoryId'), '/datasets/bronze_trip_type_csv')]",
				"[concat(variables('factoryId'), '/datasets/bronze_trip_zone_lookup')]",
				"[concat(variables('factoryId'), '/datasets/bronze_tip_zone_lookup_csv')]"
			]
		}
	]
